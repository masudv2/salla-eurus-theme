{#
| Variable          | Type       |
|-------------------|------------|
| component.heading | string     |
| component.tabs    | Collection |
| position          | int        |
#}
{% set block_id = 'eurus-skin-tabs-' ~ position %}

<section class="s-block s-block--eurus s-block--eurus-skin-tabs s-block-tabs bg-[color:var(--eurus-surface-alt)] py-14 md:py-20"
         id="{{ block_id }}"
         data-eurus="eurus-skin-tabs"
         aria-label="{{ component.heading|default('Skin tabs') }}">
  <div class="container px-4">

    {% if component.heading %}
      <h2 class="eurus-heading-display mb-8 text-center text-3xl font-bold text-[color:var(--eurus-ink)] md:text-4xl">
        {{ component.heading }}
      </h2>
    {% endif %}

    {% if component.tabs|length %}

      {# ── Tab triggers ── #}
      <div class="mb-10 flex flex-wrap items-center justify-center gap-3">
        {% for tab in component.tabs %}
          <button class="tab-trigger eurus-skin-tab-btn rounded-full border px-5 py-2 text-sm font-medium transition-colors {{ loop.first ? 'is-active bg-[color:var(--eurus-ink)] text-white border-[color:var(--eurus-ink)]' : 'bg-transparent text-[color:var(--eurus-ink)] border-[color:var(--eurus-ink)]/30 hover:border-[color:var(--eurus-ink)]' }}"
                  data-component-id="{{ block_id }}"
                  data-target="{{ block_id }}-panel-{{ loop.index0 }}">
            {{ tab.label }}
          </button>
        {% endfor %}
      </div>

      {# ── Tab panels ── #}
      <div class="tabs-wrapper">
        {% for tab in component.tabs %}
          <div id="{{ block_id }}-panel-{{ loop.index0 }}"
               class="{{ loop.first ? 'is-active opacity-100 translate-y-0' : 'inactive opacity-0 translate-y-3 hidden' }} transition-all duration-300">
            <div class="grid items-center gap-8 md:grid-cols-2 md:gap-12">

              {# Image #}
              <div>
                {% if tab.image %}
                  <img src="{{ tab.image }}"
                       alt="{{ tab.label|default('') }}"
                       class="h-auto w-full rounded-[var(--eurus-radius-image)] object-cover"
                       loading="lazy">
                {% else %}
                  <div class="flex aspect-[4/5] w-full items-center justify-center rounded-[var(--eurus-radius-image)] bg-gray-100 text-gray-300">
                    <i class="sicon-photo text-4xl"></i>
                  </div>
                {% endif %}
              </div>

              {# Text #}
              <div class="flex flex-col items-start">
                <h3 class="text-2xl font-bold text-[color:var(--eurus-ink)]">{{ tab.label }}</h3>

                {% if tab.description %}
                  <p class="mt-3 text-sm leading-relaxed text-[color:var(--eurus-ink-muted)] md:text-base">
                    {{ tab.description }}
                  </p>
                {% endif %}

                {% if tab.cta_label %}
                  <a href="{{ tab.cta_url|default('/') }}"
                     class="eurus-pill-btn mt-6 bg-[color:var(--eurus-ink)] text-white hover:opacity-90">
                    {{ tab.cta_label }}
                  </a>
                {% endif %}
              </div>

            </div>
          </div>
        {% endfor %}
      </div>

    {% endif %}
  </div>
</section>
