{#
| Variable           | Type   |
|--------------------|--------|
| component.image    | string |
| component.image_on_right | bool |
| position           | int    |
#}
<section class="s-block s-block--eurus s-block--eurus-split-banner bg-[color:var(--eurus-surface)] py-10 md:py-16">
  <div class="container px-4">
    <div
      class="flex flex-col gap-8 overflow-hidden rounded-[var(--eurus-radius-card)] bg-[color:var(--eurus-surface-alt)] md:flex-row md:items-stretch md:gap-0
      {{ component.image_on_right ? 'md:flex-row-reverse rtl:md:flex-row' : 'rtl:md:flex-row-reverse' }}"
    >
      <div class="relative min-h-[240px] md:w-1/2 md:min-h-[360px]">
        {% if component.image %}
          <img
            src="{{ component.image }}"
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            width="800"
            height="600"
          />
        {% endif %}
      </div>
      <div class="flex flex-col justify-center px-6 py-8 md:w-1/2 md:px-12 md:py-12">
        {% if component.title %}
          <h2 class="text-2xl font-bold leading-tight text-[color:var(--eurus-ink)] md:text-3xl">
            {{ component.title }}
          </h2>
        {% endif %}
        {% if component.description %}
          <p class="mt-4 text-sm leading-relaxed text-[color:var(--eurus-ink-muted)] md:text-base">
            {{ component.description }}
          </p>
        {% endif %}
        {% if component.cta_label and component.cta_url %}
          <div class="mt-8">
            <a
              href="{{ component.cta_url }}"
              class="inline-flex items-center justify-center rounded-full border-2 border-[color:var(--eurus-ink)] px-6 py-3 text-sm font-semibold text-[color:var(--eurus-ink)] transition-colors hover:bg-[color:var(--eurus-ink)] hover:text-white"
            >
              {{ component.cta_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
