{#
| Variable          | Type     |
|-------------------|----------|
| component.pills[] | object[] |
| position          | int      |
#}
<section class="s-block s-block--eurus s-block--eurus-category-pills bg-[color:var(--eurus-surface)] py-10 md:py-14">
  <div class="container px-4">
    {% if component.section_title %}
      <h2 class="mb-8 text-center text-2xl font-bold text-[color:var(--eurus-ink)] md:text-3xl">
        {{ component.section_title }}
      </h2>
    {% endif %}
    {% if component.pills|length %}
      <div class="hide-scroll flex gap-4 overflow-x-auto pb-2 md:justify-center md:overflow-visible">
        {% for pill in component.pills %}
          <a
            href="{{ pill.url }}"
            class="group flex min-w-[100px] flex-col items-center gap-3 text-center md:min-w-[120px]"
          >
            <span class="block h-24 w-24 overflow-hidden rounded-full border border-gray-200/80 bg-white shadow-sm transition group-hover:shadow md:h-28 md:w-28">
              {% if pill.image %}
                <img
                  src="{{ pill.image }}"
                  alt=""
                  class="h-full w-full object-cover"
                  loading="lazy"
                  width="112"
                  height="112"
                />
              {% endif %}
            </span>
            {% if pill.label %}
              <span class="text-sm font-semibold text-[color:var(--eurus-ink)]">{{ pill.label }}</span>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
