{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}
    {# `{% component home %}` only outputs blocks saved in the store / theme editor.
       `is_default` in twilight.json does not always seed existing drafts — use the built-in
       Eurus stack unless the merchant opts into editor-only mode in theme settings. #}
    {% if theme.settings.get('eurus_use_editor_homepage', false) %}
        {% component home %}
    {% else %}
        {% include 'partials/eurus-static-home.twig' %}
    {% endif %}
{% endblock %}
{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
{% endblock %}